using System;
using System.ComponentModel;
using System.Diagnostics;
using System.IO;
using System.Runtime.InteropServices;

namespace nanoFramework.Tools.FirmwareFlasher
{
    /// <summary>
    /// Installs/uninstalls a WinUSB driver for the Pico PICOBOOT interface.
    /// On Windows, uses a self-signed certificate + signed catalog + pnputil.
    /// On Linux, creates a udev rule. On macOS, no driver is needed.
    /// </summary>
    public static class PicoBootDriverHelper
    {
        private const string DeviceInterfaceGuid = "{D1228F5E-8C92-4B78-B104-FED3957E4E46}";
        private const string InfBaseName = "picoboot_winusb";
        private const string CertSubject = "CN=nanoFramework PICOBOOT";
        private const string UdevRulesFile = "99-picoboot.rules";

        private static readonly string[] HardwareIds =
        [
            "USB\\VID_2E8A&PID_0003&MI_01",  // RP2040 BOOTSEL
            "USB\\VID_2E8A&PID_000F&MI_01",  // RP2350 BOOTSEL
        ];

        public static ExitCodes InstallDrivers(VerbosityLevel verbosity)
        {
            if (RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
            {
                OutputWriter.WriteLine("No driver installation needed on macOS. PICOBOOT works out of the box.");
                return ExitCodes.OK;
            }

            if (RuntimeInformation.IsOSPlatform(OSPlatform.Linux))
            {
                return InstallLinuxUdevRule(verbosity);
            }

            return InstallWindowsDriver(verbosity);
        }

        public static ExitCodes UninstallDrivers(VerbosityLevel verbosity)
        {
            if (RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
            {
                OutputWriter.WriteLine("No driver to uninstall on macOS.");
                return ExitCodes.OK;
            }

            if (RuntimeInformation.IsOSPlatform(OSPlatform.Linux))
            {
                return UninstallLinuxUdevRule(verbosity);
            }

            return UninstallWindowsDriver(verbosity);
        }

        #region Windows

        private static ExitCodes InstallWindowsDriver(VerbosityLevel verbosity)
        {
            try
            {
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("=== PICOBOOT WinUSB Driver Installation ===");
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("This will install a WinUSB driver for the Raspberry Pi Pico PICOBOOT interface.");
                OutputWriter.WriteLine("This enables direct USB flash operations (--picoboot) without needing Zadig.");
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("What this does:");
                OutputWriter.WriteLine("  - Creates a temporary self-signed certificate to sign the driver package");
                OutputWriter.WriteLine("  - Registers a WinUSB driver for the Pico BOOTSEL-mode vendor interface");
                OutputWriter.WriteLine("  - Covers both RP2040 and RP2350 devices");
                OutputWriter.WriteLine("  - This is a one-time operation; the driver persists across reboots");
                OutputWriter.WriteLine("");
                OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                OutputWriter.WriteLine("NOTE: This requires administrator privileges. Windows will show a UAC prompt.");
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");

                string tempDir = Path.Combine(Path.GetTempPath(), $"nanoff_picoboot_{Guid.NewGuid():N}");
                Directory.CreateDirectory(tempDir);

                try
                {
                    string infPath = Path.Combine(tempDir, $"{InfBaseName}.inf");
                    File.WriteAllText(infPath, GenerateWinUsbInf());

                    string resultPath = Path.Combine(tempDir, "result.txt");
                    string scriptPath = Path.Combine(tempDir, "install_driver.ps1");
                    File.WriteAllText(scriptPath, GenerateInstallScript(tempDir, resultPath));

                    if (verbosity >= VerbosityLevel.Detailed)
                    {
                        OutputWriter.WriteLine($"Working directory: {tempDir}");
                    }

                    if (verbosity >= VerbosityLevel.Normal)
                    {
                        OutputWriter.ForegroundColor = ConsoleColor.Cyan;
                        OutputWriter.Write("Installing PICOBOOT WinUSB driver...");
                    }

                    ExitCodes runResult = RunElevatedPowerShellScript(scriptPath);

                    if (runResult != ExitCodes.OK)
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                            OutputWriter.WriteLine(" cancelled by user.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.WriteLine("The operation was cancelled (UAC prompt was denied).");

                        return ExitCodes.E3008;
                    }

                    if (!File.Exists(resultPath))
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Red;
                            OutputWriter.WriteLine(" failed.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.WriteLine("The elevated script did not produce a result. Check that PowerShell 5.1+ is available.");

                        return ExitCodes.E3008;
                    }

                    string resultText = File.ReadAllText(resultPath).Trim();

                    if (resultText.StartsWith("SUCCESS", StringComparison.OrdinalIgnoreCase))
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Green;
                            OutputWriter.WriteLine(" OK");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.ForegroundColor = ConsoleColor.Green;
                        OutputWriter.WriteLine("Driver installation completed successfully.");
                        OutputWriter.ForegroundColor = ConsoleColor.White;
                        OutputWriter.WriteLine("");
                        OutputWriter.WriteLine("You can now use --picoboot for direct USB flash operations.");
                        OutputWriter.WriteLine("If a Pico is currently connected in BOOTSEL mode, unplug and replug it for the driver to take effect.");
                        OutputWriter.WriteLine("");
                        OutputWriter.WriteLine("To uninstall this driver later, run: nanoff --platform rpi_pico --uninstallpicobootdrivers");

                        return ExitCodes.OK;
                    }
                    else
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Red;
                            OutputWriter.WriteLine(" failed.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.ForegroundColor = ConsoleColor.Red;
                        OutputWriter.WriteLine(resultText);
                        OutputWriter.ForegroundColor = ConsoleColor.White;

                        return ExitCodes.E3008;
                    }
                }
                finally
                {
                    try
                    {
                        Directory.Delete(tempDir, true);
                    }
                    catch
                    {
                        // best effort cleanup
                    }
                }
            }
            catch (Exception ex)
            {
                OutputWriter.ForegroundColor = ConsoleColor.Red;
                OutputWriter.WriteLine($"\nERROR: Failed to install PICOBOOT driver: {ex.Message}");
                OutputWriter.ForegroundColor = ConsoleColor.White;

                return ExitCodes.E3008;
            }
        }

        private static ExitCodes UninstallWindowsDriver(VerbosityLevel verbosity)
        {
            try
            {
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("=== PICOBOOT WinUSB Driver Removal ===");
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("This will remove the previously installed WinUSB driver for the Pico PICOBOOT interface.");
                OutputWriter.WriteLine("After removal, --picoboot will no longer work until the driver is reinstalled.");
                OutputWriter.WriteLine("");
                OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                OutputWriter.WriteLine("NOTE: This requires administrator privileges. Windows will show a UAC prompt.");
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Cyan;
                    OutputWriter.Write("Searching for installed PICOBOOT driver...");
                }

                var enumProcess = new Process
                {
                    StartInfo = new ProcessStartInfo("pnputil")
                    {
                        Arguments = "/enum-drivers",
                        UseShellExecute = false,
                        RedirectStandardOutput = true,
                        CreateNoWindow = true
                    }
                };

                enumProcess.Start();
                string output = enumProcess.StandardOutput.ReadToEnd();
                enumProcess.WaitForExit();

                string oemInfName = FindOemInfName(output);

                if (string.IsNullOrEmpty(oemInfName))
                {
                    if (verbosity >= VerbosityLevel.Normal)
                    {
                        OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                        OutputWriter.WriteLine(" not found.");
                        OutputWriter.ForegroundColor = ConsoleColor.White;
                    }

                    OutputWriter.WriteLine("");
                    OutputWriter.WriteLine("No PICOBOOT WinUSB driver is currently installed.");
                    OutputWriter.WriteLine("Nothing to uninstall.");

                    return ExitCodes.OK;
                }

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Green;
                    OutputWriter.WriteLine($" found: {oemInfName}");
                    OutputWriter.ForegroundColor = ConsoleColor.White;
                }

                string tempDir = Path.Combine(Path.GetTempPath(), $"nanoff_picoboot_{Guid.NewGuid():N}");
                Directory.CreateDirectory(tempDir);

                try
                {
                    string resultPath = Path.Combine(tempDir, "result.txt");
                    string scriptPath = Path.Combine(tempDir, "uninstall_driver.ps1");
                    File.WriteAllText(scriptPath, GenerateUninstallScript(oemInfName, resultPath));

                    if (verbosity >= VerbosityLevel.Normal)
                    {
                        OutputWriter.ForegroundColor = ConsoleColor.Cyan;
                        OutputWriter.Write("Removing driver and certificate...");
                    }

                    ExitCodes runResult = RunElevatedPowerShellScript(scriptPath);

                    if (runResult != ExitCodes.OK)
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                            OutputWriter.WriteLine(" cancelled by user.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        return ExitCodes.E3008;
                    }

                    if (!File.Exists(resultPath))
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Red;
                            OutputWriter.WriteLine(" failed.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        return ExitCodes.E3008;
                    }

                    string resultText = File.ReadAllText(resultPath).Trim();

                    if (resultText.StartsWith("SUCCESS", StringComparison.OrdinalIgnoreCase))
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Green;
                            OutputWriter.WriteLine(" OK");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.ForegroundColor = ConsoleColor.Green;
                        OutputWriter.WriteLine("Driver removal completed.");
                        OutputWriter.ForegroundColor = ConsoleColor.White;
                        OutputWriter.WriteLine("");
                        OutputWriter.WriteLine("The --picoboot option will no longer work until the driver is reinstalled.");
                        OutputWriter.WriteLine("You can still use the default UF2 mass storage path for flashing.");
                        OutputWriter.WriteLine("If a Pico is currently connected, unplug and replug it.");

                        return ExitCodes.OK;
                    }
                    else
                    {
                        if (verbosity >= VerbosityLevel.Normal)
                        {
                            OutputWriter.ForegroundColor = ConsoleColor.Red;
                            OutputWriter.WriteLine(" failed.");
                            OutputWriter.ForegroundColor = ConsoleColor.White;
                        }

                        OutputWriter.WriteLine("");
                        OutputWriter.ForegroundColor = ConsoleColor.Red;
                        OutputWriter.WriteLine(resultText);
                        OutputWriter.ForegroundColor = ConsoleColor.White;

                        return ExitCodes.E3008;
                    }
                }
                finally
                {
                    try
                    {
                        Directory.Delete(tempDir, true);
                    }
                    catch
                    {
                        // best effort
                    }
                }
            }
            catch (Exception ex)
            {
                OutputWriter.ForegroundColor = ConsoleColor.Red;
                OutputWriter.WriteLine($"\nERROR: Failed to uninstall PICOBOOT driver: {ex.Message}");
                OutputWriter.ForegroundColor = ConsoleColor.White;

                return ExitCodes.E3008;
            }
        }

        private static ExitCodes RunElevatedPowerShellScript(string scriptPath)
        {
            try
            {
                var process = new Process
                {
                    StartInfo = new ProcessStartInfo("powershell.exe")
                    {
                        Arguments = $"-ExecutionPolicy Bypass -NoProfile -WindowStyle Hidden -File \"{scriptPath}\"",
                        UseShellExecute = true,
                        Verb = "runas"
                    }
                };

                process.Start();
                process.WaitForExit();

                return ExitCodes.OK;
            }
            catch (Win32Exception)
            {
                // user cancelled UAC prompt
                return ExitCodes.E3008;
            }
        }

        private static string FindOemInfName(string pnputilOutput)
        {
            string[] lines = pnputilOutput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            for (int i = 0; i < lines.Length; i++)
            {
                string line = lines[i].Trim();

                if (line.Contains("Original Name") && line.Contains(InfBaseName))
                {
                    for (int j = i - 1; j >= Math.Max(0, i - 5); j--)
                    {
                        string prevLine = lines[j].Trim();

                        if (prevLine.StartsWith("Published Name", StringComparison.OrdinalIgnoreCase))
                        {
                            int colonIdx = prevLine.IndexOf(':');

                            if (colonIdx > 0)
                            {
                                return prevLine.Substring(colonIdx + 1).Trim();
                            }

                            break;
                        }
                    }

                    break;
                }
            }

            return null;
        }

        private static string GenerateWinUsbInf()
        {
            return $@";
; WinUSB driver for Raspberry Pi Pico PICOBOOT interface
; Generated by nanoFramework Firmware Flasher (nanoff)
;

[Version]
Signature   = ""$Windows NT$""
Class       = USBDevice
ClassGUID   = {{88BAE032-5A81-49f0-BC3D-A4FF138216D6}}
Provider    = %ManufacturerName%
CatalogFile = {InfBaseName}.cat
DriverVer   = 01/01/2024,1.0.0.0

[Manufacturer]
%ManufacturerName% = Standard,NTamd64,NTarm64

[Standard.NTamd64]
%DeviceName_RP2040% = USB_Install, {HardwareIds[0]}
%DeviceName_RP2350% = USB_Install, {HardwareIds[1]}

[Standard.NTarm64]
%DeviceName_RP2040% = USB_Install, {HardwareIds[0]}
%DeviceName_RP2350% = USB_Install, {HardwareIds[1]}

[USB_Install]
Include = winusb.inf
Needs   = WINUSB.NT

[USB_Install.Services]
Include = winusb.inf
Needs   = WINUSB.NT.Services

[USB_Install.HW]
AddReg = Dev_AddReg

[Dev_AddReg]
HKR,,DeviceInterfaceGUIDs,0x10000,""{DeviceInterfaceGuid}""

[Strings]
ManufacturerName = ""Raspberry Pi""
DeviceName_RP2040 = ""RP2040 PICOBOOT Interface""
DeviceName_RP2350 = ""RP2350 PICOBOOT Interface""
";
        }

        private static string GenerateInstallScript(string tempDir, string resultPath)
        {
            string infFileName = $"{InfBaseName}.inf";
            string catFileName = $"{InfBaseName}.cat";

            // Plain string with placeholders — avoids C# interpolation escaping issues
            // PowerShell variables ($cert, $store, etc.) are NOT interpolated by C# since
            // C# string interpolation only triggers on { } not on $
            string script = @"
$ErrorActionPreference = 'Stop'
try {
    $infDir = '__TEMPDIR__'
    $infFile = Join-Path $infDir '__INFFILE__'
    $catFile = Join-Path $infDir '__CATFILE__'
    $resultFile = '__RESULTFILE__'

    # Create a self-signed code-signing certificate (valid 10 years)
    $cert = New-SelfSignedCertificate `
        -Subject '__CERTSUBJECT__' `
        -Type CodeSigningCert `
        -CertStoreLocation 'Cert:\LocalMachine\My' `
        -NotAfter (Get-Date).AddYears(10)

    # Add certificate to trusted stores so the signed catalog is accepted
    $pubStore = [System.Security.Cryptography.X509Certificates.X509Store]::new('TrustedPublisher', 'LocalMachine')
    $pubStore.Open('ReadWrite')
    $pubStore.Add($cert)
    $pubStore.Close()

    $rootStore = [System.Security.Cryptography.X509Certificates.X509Store]::new('Root', 'LocalMachine')
    $rootStore.Open('ReadWrite')
    $rootStore.Add($cert)
    $rootStore.Close()

    # Create a catalog file from the INF
    New-FileCatalog -CatalogFilePath $catFile -Path $infFile -CatalogVersion 2 | Out-Null

    # Sign the catalog with our self-signed certificate
    Set-AuthenticodeSignature -FilePath $catFile -Certificate $cert | Out-Null

    # Install the signed driver package via pnputil
    $output = & pnputil /add-driver $infFile /install 2>&1
    $pnpExitCode = $LASTEXITCODE

    # Remove certificate from the personal store (keep in TrustedPublisher/Root for driver verification)
    $myStore = [System.Security.Cryptography.X509Certificates.X509Store]::new('My', 'LocalMachine')
    $myStore.Open('ReadWrite')
    $myStore.Remove($cert)
    $myStore.Close()

    if ($pnpExitCode -eq 0) {
        'SUCCESS' | Out-File -FilePath $resultFile -Encoding UTF8
    } else {
        (""ERROR: pnputil exited with code $pnpExitCode"" + ""`r`n"" + ($output -join ""`r`n"")) | Out-File -FilePath $resultFile -Encoding UTF8
    }
} catch {
    (""ERROR: "" + $_.Exception.Message) | Out-File -FilePath '__RESULTFILE__' -Encoding UTF8
}
";
            return script
                .Replace("__TEMPDIR__", tempDir)
                .Replace("__INFFILE__", infFileName)
                .Replace("__CATFILE__", catFileName)
                .Replace("__RESULTFILE__", resultPath)
                .Replace("__CERTSUBJECT__", CertSubject);
        }

        private static string GenerateUninstallScript(string oemInfName, string resultPath)
        {
            string script = @"
$ErrorActionPreference = 'Stop'
try {
    $resultFile = '__RESULTFILE__'

    # Remove the driver package
    $output = & pnputil /delete-driver __OEMINF__ /uninstall /force 2>&1
    $pnpExitCode = $LASTEXITCODE

    # Clean up the self-signed certificate from trusted stores
    $subject = '__CERTSUBJECT__'

    foreach ($storeName in @('TrustedPublisher', 'Root', 'My')) {
        $store = [System.Security.Cryptography.X509Certificates.X509Store]::new($storeName, 'LocalMachine')
        $store.Open('ReadWrite')
        $certsToRemove = $store.Certificates | Where-Object { $_.Subject -eq $subject }
        foreach ($c in $certsToRemove) {
            $store.Remove($c)
        }
        $store.Close()
    }

    if ($pnpExitCode -eq 0) {
        'SUCCESS' | Out-File -FilePath $resultFile -Encoding UTF8
    } else {
        (""ERROR: pnputil exited with code $pnpExitCode"" + ""`r`n"" + ($output -join ""`r`n"")) | Out-File -FilePath $resultFile -Encoding UTF8
    }
} catch {
    (""ERROR: "" + $_.Exception.Message) | Out-File -FilePath '__RESULTFILE__' -Encoding UTF8
}
";
            return script
                .Replace("__RESULTFILE__", resultPath)
                .Replace("__OEMINF__", oemInfName)
                .Replace("__CERTSUBJECT__", CertSubject);
        }

        #endregion

        #region Linux

        private static ExitCodes InstallLinuxUdevRule(VerbosityLevel verbosity)
        {
            try
            {
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("=== PICOBOOT udev Rule Installation ===");
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("This will install a udev rule to allow non-root access to Pico devices.");
                OutputWriter.WriteLine("This enables --picoboot operations without running as root.");
                OutputWriter.WriteLine("");
                OutputWriter.ForegroundColor = ConsoleColor.Yellow;
                OutputWriter.WriteLine("NOTE: This requires sudo privileges. You may be prompted for your password.");
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");

                string rulesContent =
                    "# Raspberry Pi Pico - PICOBOOT interface (generated by nanoff)\n" +
                    "# RP2040 BOOTSEL mode\n" +
                    "SUBSYSTEM==\"usb\", ATTR{idVendor}==\"2e8a\", ATTR{idProduct}==\"0003\", MODE=\"0666\"\n" +
                    "# RP2350 BOOTSEL mode\n" +
                    "SUBSYSTEM==\"usb\", ATTR{idVendor}==\"2e8a\", ATTR{idProduct}==\"000f\", MODE=\"0666\"\n" +
                    "# RP2040 running with USB stdio\n" +
                    "SUBSYSTEM==\"usb\", ATTR{idVendor}==\"2e8a\", ATTR{idProduct}==\"0009\", MODE=\"0666\"\n" +
                    "# RP2350 running with USB stdio\n" +
                    "SUBSYSTEM==\"usb\", ATTR{idVendor}==\"2e8a\", ATTR{idProduct}==\"000a\", MODE=\"0666\"\n";

                string tempPath = Path.Combine(Path.GetTempPath(), UdevRulesFile);
                File.WriteAllText(tempPath, rulesContent);

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Cyan;
                    OutputWriter.Write("Installing udev rule...");
                }

                var process = new Process
                {
                    StartInfo = new ProcessStartInfo("sudo")
                    {
                        Arguments = $"cp \"{tempPath}\" /etc/udev/rules.d/{UdevRulesFile}",
                        UseShellExecute = true
                    }
                };

                process.Start();
                process.WaitForExit();

                var reload = new Process
                {
                    StartInfo = new ProcessStartInfo("sudo")
                    {
                        Arguments = "udevadm control --reload-rules",
                        UseShellExecute = true
                    }
                };

                reload.Start();
                reload.WaitForExit();

                try
                {
                    File.Delete(tempPath);
                }
                catch
                {
                    // best effort
                }

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Green;
                    OutputWriter.WriteLine(" OK");
                    OutputWriter.ForegroundColor = ConsoleColor.White;
                }

                OutputWriter.WriteLine("");
                OutputWriter.ForegroundColor = ConsoleColor.Green;
                OutputWriter.WriteLine("udev rule installed.");
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("You can now use --picoboot for direct USB flash operations.");
                OutputWriter.WriteLine("If a Pico is currently connected, unplug and replug it.");

                return ExitCodes.OK;
            }
            catch (Exception ex)
            {
                OutputWriter.ForegroundColor = ConsoleColor.Red;
                OutputWriter.WriteLine($"ERROR: Failed to install udev rule: {ex.Message}");
                OutputWriter.ForegroundColor = ConsoleColor.White;

                return ExitCodes.E3008;
            }
        }

        private static ExitCodes UninstallLinuxUdevRule(VerbosityLevel verbosity)
        {
            try
            {
                OutputWriter.ForegroundColor = ConsoleColor.White;
                OutputWriter.WriteLine("");
                OutputWriter.WriteLine("=== PICOBOOT udev Rule Removal ===");
                OutputWriter.WriteLine("");

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Cyan;
                    OutputWriter.Write("Removing udev rule...");
                }

                var process = new Process
                {
                    StartInfo = new ProcessStartInfo("sudo")
                    {
                        Arguments = $"rm -f /etc/udev/rules.d/{UdevRulesFile}",
                        UseShellExecute = true
                    }
                };

                process.Start();
                process.WaitForExit();

                var reload = new Process
                {
                    StartInfo = new ProcessStartInfo("sudo")
                    {
                        Arguments = "udevadm control --reload-rules",
                        UseShellExecute = true
                    }
                };

                reload.Start();
                reload.WaitForExit();

                if (verbosity >= VerbosityLevel.Normal)
                {
                    OutputWriter.ForegroundColor = ConsoleColor.Green;
                    OutputWriter.WriteLine(" OK");
                    OutputWriter.ForegroundColor = ConsoleColor.White;
                }

                OutputWriter.WriteLine("");
                OutputWriter.ForegroundColor = ConsoleColor.Green;
                OutputWriter.WriteLine("udev rule removed.");
                OutputWriter.ForegroundColor = ConsoleColor.White;

                return ExitCodes.OK;
            }
            catch (Exception ex)
            {
                OutputWriter.ForegroundColor = ConsoleColor.Red;
                OutputWriter.WriteLine($"ERROR: Failed to remove udev rule: {ex.Message}");
                OutputWriter.ForegroundColor = ConsoleColor.White;

                return ExitCodes.E3008;
            }
        }

        #endregion
    }
}
