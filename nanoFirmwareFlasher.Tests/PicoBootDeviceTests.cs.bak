using System;
using Microsoft.VisualStudio.TestTools.UnitTesting;
using nanoFirmwareFlasher.Tests.Helpers;
using nanoFramework.Tools.FirmwareFlasher;

namespace nanoFirmwareFlasher.Tests
{
    [TestClass]
    [TestCategory("Pico")]
    public class PicoBootDeviceTests
    {
        #region Device Discovery

        [TestMethod]
        public void FindDevices_ReturnsListWithoutCrash()
        {
            // FindDevices should return an empty list if no hardware is connected
            // This tests that the USB enumeration code doesn't crash
            var devices = PicoBootDevice.FindDevices();

            Assert.IsNotNull(devices);
            // not asserting Count>0 since no hardware may be connected in CI
        }

        [TestMethod]
        public void OpenFirst_NullWhenNoDevice()
        {
            // when no device is connected, OpenFirst should return null gracefully
            PicoBootDevice device = PicoBootDevice.OpenFirst();

            // if a device happens to be connected, dispose it
            device?.Dispose();

            // this test just confirms no exception is thrown
        }

        #endregion

        #region PicoBootDeviceInfo

        [TestMethod]
        public void PicoBootDeviceInfo_Properties()
        {
            var info = new PicoBootDeviceInfo("RP2040", 0x2E8A, 0x0003, @"\\?\usb#vid_2e8a");

            Assert.AreEqual("RP2040", info.ChipType);
            Assert.AreEqual(0x2E8A, info.Vid);
            Assert.AreEqual(0x0003, info.Pid);
            Assert.AreEqual(@"\\?\usb#vid_2e8a", info.DevicePath);
        }

        [TestMethod]
        public void PicoBootDeviceInfo_RP2350_Properties()
        {
            var info = new PicoBootDeviceInfo("RP2350", 0x2E8A, 0x000F, "/dev/bus/usb/001/002");

            Assert.AreEqual("RP2350", info.ChipType);
            Assert.AreEqual(0x2E8A, info.Vid);
            Assert.AreEqual(0x000F, info.Pid);
        }

        [TestMethod]
        public void PicoBootDeviceInfo_ToString_ContainsAllFields()
        {
            var info = new PicoBootDeviceInfo("RP2040", 0x2E8A, 0x0003, @"\\?\usb#test");
            string output = info.ToString();

            Assert.IsTrue(output.Contains("RP2040"));
            Assert.IsTrue(output.Contains("2E8A"));
            Assert.IsTrue(output.Contains("0003"));
        }

        #endregion

        #region CLI Options

        [TestMethod]
        [DoNotParallelize]
        public void PicoManager_PicoBootOption_Constructs()
        {
            using var output = new OutputWriterHelper();

            var options = new Options
            {
                Platform = SupportedPlatform.rpi_pico,
                UsePicoBoot = true,
                Update = true,
                TargetName = "RASPBERRY_PI_PICO"
            };

            var manager = new PicoManager(options, VerbosityLevel.Quiet);
            Assert.IsNotNull(manager);
        }

        [TestMethod]
        [DoNotParallelize]
        public void PicoManager_VerifyOption_Constructs()
        {
            using var output = new OutputWriterHelper();

            var options = new Options
            {
                Platform = SupportedPlatform.rpi_pico,
                UsePicoBoot = true,
                VerifyAfterFlash = true,
                Update = true,
                TargetName = "RASPBERRY_PI_PICO"
            };

            var manager = new PicoManager(options, VerbosityLevel.Quiet);
            Assert.IsNotNull(manager);
        }

        [TestMethod]
        public void Options_PicoBootProperties_Exist()
        {
            // verify that all new CLI option properties exist and have correct defaults
            var options = new Options();

            Assert.IsFalse(options.UsePicoBoot);
            Assert.IsFalse(options.VerifyAfterFlash);
            Assert.IsNull(options.ReadFlashFile);
            Assert.IsNull(options.OtpDumpFile);
        }

        #endregion

        #region Protocol Constants

        [TestMethod]
        public void PicoBootDeviceInfo_KnownPids()
        {
            // RP2040 BOOTSEL mode PID is 0x0003
            var rp2040 = new PicoBootDeviceInfo("RP2040", 0x2E8A, 0x0003, "");
            Assert.AreEqual(0x0003, rp2040.Pid);

            // RP2350 BOOTSEL mode PID is 0x000F
            var rp2350 = new PicoBootDeviceInfo("RP2350", 0x2E8A, 0x000F, "");
            Assert.AreEqual(0x000F, rp2350.Pid);
        }

        [TestMethod]
        public void InfoTypeConstants_HaveCorrectValues()
        {
            Assert.AreEqual(0x01u, PicoBootDevice.InfoTypeSys);
            Assert.AreEqual(0x02u, PicoBootDevice.InfoTypePartitions);
            Assert.AreEqual(0x04u, PicoBootDevice.InfoTypeUf2Status);
        }

        #endregion

        #region PicoDeviceExtendedInfo

        [TestMethod]
        public void ParseTlvResponse_EmptyData_ReturnsEmpty()
        {
            var items = PicoDeviceExtendedInfo.ParseTlvResponse(null);
            Assert.AreEqual(0, items.Count);

            items = PicoDeviceExtendedInfo.ParseTlvResponse(Array.Empty<byte>());
            Assert.AreEqual(0, items.Count);

            items = PicoDeviceExtendedInfo.ParseTlvResponse(new byte[] { 0x01 });
            Assert.AreEqual(0, items.Count);
        }

        [TestMethod]
        public void ParseTlvResponse_SingleItem_Parsed()
        {
            // tag=0x01, count=1, value=0x12345678 (little-endian)
            byte[] data = { 0x01, 0x01, 0x78, 0x56, 0x34, 0x12 };

            var items = PicoDeviceExtendedInfo.ParseTlvResponse(data);

            Assert.AreEqual(1, items.Count);
            Assert.IsTrue(items.ContainsKey(0x01));
            Assert.AreEqual(1, items[0x01].Count);
            Assert.AreEqual(0x12345678u, items[0x01][0]);
        }

        [TestMethod]
        public void ParseTlvResponse_MultipleItems_Parsed()
        {
            // tag=0x01 count=1 val=0xAAAAAAAA | tag=0x03 count=2 val=0xBBBBBBBB 0xCCCCCCCC
            byte[] data = {
                0x01, 0x01, 0xAA, 0xAA, 0xAA, 0xAA,
                0x03, 0x02, 0xBB, 0xBB, 0xBB, 0xBB, 0xCC, 0xCC, 0xCC, 0xCC
            };

            var items = PicoDeviceExtendedInfo.ParseTlvResponse(data);

            Assert.AreEqual(2, items.Count);
            Assert.AreEqual(0xAAAAAAAAu, items[0x01][0]);
            Assert.AreEqual(2, items[0x03].Count);
            Assert.AreEqual(0xBBBBBBBBu, items[0x03][0]);
            Assert.AreEqual(0xCCCCCCCCu, items[0x03][1]);
        }

        [TestMethod]
        public void ParseTlvResponse_TruncatedData_StopsGracefully()
        {
            // tag=0x01, count=2, but only 1 uint32 of data (truncated)
            byte[] data = { 0x01, 0x02, 0x78, 0x56, 0x34, 0x12 };

            var items = PicoDeviceExtendedInfo.ParseTlvResponse(data);

            // should stop parsing without crash — count=2 requires 8 bytes, only 4 available
            Assert.AreEqual(0, items.Count);
        }

        [TestMethod]
        public void ExtendedInfo_RP2350_WithFlashJedec()
        {
            // simulate SYS info with flash device info: tag=0x03, count=1, value=0x001840EF (Winbond W25Q256)
            byte[] sysInfo = { 0x03, 0x01, 0xEF, 0x40, 0x18, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", sysInfo, null, null);

            Assert.AreEqual("RP2350", info.ChipType);
            Assert.IsNotNull(info.FlashJedecId);
            Assert.AreEqual(0x001840EFu, info.FlashJedecId.Value);
        }

        [TestMethod]
        public void ExtendedInfo_RP2350_WithOtpCritical()
        {
            // simulate OTP CRIT0 = 0x0001 (secure boot enabled), CRIT1 = 0x0000
            byte[] otpCritical = { 0x01, 0x00, 0x00, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);

            Assert.IsNotNull(info.Crit0Flags);
            Assert.AreEqual((ushort)0x0001, info.Crit0Flags!.Value);
            Assert.IsTrue(info.SecureBootEnabled!.Value);
            Assert.IsFalse(info.DebugDisabled!.Value);
        }

        [TestMethod]
        public void ExtendedInfo_RP2350_SecureBootDisabled()
        {
            // CRIT0 = 0x0000 (nothing enabled)
            byte[] otpCritical = { 0x00, 0x00, 0x00, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);

            Assert.IsFalse(info.SecureBootEnabled!.Value);
            Assert.IsFalse(info.DebugDisabled!.Value);
        }

        [TestMethod]
        public void ExtendedInfo_RP2350_DebugDisabled()
        {
            // CRIT0 = 0x0004 (debug disabled)
            byte[] otpCritical = { 0x04, 0x00, 0x00, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);

            Assert.IsFalse(info.SecureBootEnabled!.Value);
            Assert.IsTrue(info.DebugDisabled!.Value);
        }

        [TestMethod]
        public void ExtendedInfo_RP2040_NoExtendedData()
        {
            var info = new PicoDeviceExtendedInfo("RP2040", null, null, null);

            Assert.AreEqual("RP2040", info.ChipType);
            Assert.IsNull(info.FlashJedecId);
            Assert.IsNull(info.SecureBootEnabled);
            Assert.IsNull(info.DebugDisabled);
            Assert.IsNull(info.Crit0Flags);
        }

        [TestMethod]
        public void ExtendedInfo_ToString_ContainsChipType()
        {
            var info = new PicoDeviceExtendedInfo("RP2350", null, null, null);
            string output = info.ToString();

            Assert.IsTrue(output.Contains("RP2350"));
            Assert.IsTrue(output.Contains("PICOBOOT USB"));
        }

        [TestMethod]
        public void ExtendedInfo_ToString_ShowsSecureBoot()
        {
            byte[] otpCritical = { 0x01, 0x00, 0x00, 0x00 };
            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);
            string output = info.ToString();

            Assert.IsTrue(output.Contains("Secure boot: Enabled"));
        }

        [TestMethod]
        public void FormatFlashJedecId_KnownManufacturers()
        {
            // Winbond W25Q128JV: 0xEF, type=0x40, capacity=0x18
            string result = PicoDeviceExtendedInfo.FormatFlashJedecId(0x001840EF);
            Assert.IsTrue(result.Contains("Winbond"));

            // GigaDevice
            result = PicoDeviceExtendedInfo.FormatFlashJedecId(0x001540C8);
            Assert.IsTrue(result.Contains("GigaDevice"));

            // Unknown manufacturer
            result = PicoDeviceExtendedInfo.FormatFlashJedecId(0x001540FF);
            Assert.IsTrue(result.Contains("Unknown"));
        }

