        [TestMethod]
        public void ExtendedInfo_CombinedFlags_SecureBootAndDebugDisabled()
        {
            // CRIT0 = 0x0005 (secure boot + debug disabled)
            byte[] otpCritical = { 0x05, 0x00, 0x00, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);

            Assert.IsTrue(info.SecureBootEnabled!.Value);
            Assert.IsTrue(info.DebugDisabled!.Value);
        }

        [TestMethod]
        public void ExtendedInfo_WithSysAndOtp_AllFieldsPopulated()
        {
            // SYS info with flash JEDEC: tag=0x03, count=1, val=0x001840EF (Winbond W25Q256)
            byte[] sysInfo = { 0x03, 0x01, 0xEF, 0x40, 0x18, 0x00 };
            // OTP crit: secure boot enabled
            byte[] otpCritical = { 0x01, 0x00, 0x00, 0x00 };

            var info = new PicoDeviceExtendedInfo("RP2350", sysInfo, null, otpCritical);

            Assert.AreEqual("RP2350", info.ChipType);
            Assert.IsNotNull(info.FlashJedecId);
            Assert.AreEqual(0x001840EFu, info.FlashJedecId.Value);
            Assert.IsTrue(info.SecureBootEnabled!.Value);
            Assert.IsFalse(info.DebugDisabled!.Value);
        }

        [TestMethod]
        public void ExtendedInfo_ToString_ShowsDebugDisabled()
        {
            byte[] otpCritical = { 0x04, 0x00, 0x00, 0x00 };
            var info = new PicoDeviceExtendedInfo("RP2350", null, null, otpCritical);
            string output = info.ToString();

            Assert.IsTrue(output.Contains("Debug: Disabled"));
        }

        [TestMethod]
        public void ExtendedInfo_ToString_ShowsFlashJedec()
        {
            byte[] sysInfo = { 0x03, 0x01, 0xEF, 0x40, 0x18, 0x00 };
            var info = new PicoDeviceExtendedInfo("RP2350", sysInfo, null, null);
            string output = info.ToString();

            Assert.IsTrue(output.Contains("Flash"));
            Assert.IsTrue(output.Contains("Winbond"));
        }

